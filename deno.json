{
  "name": "@quad/openfeature-provider-postgres",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "exports": "./src/index.ts",
  "publish": {
    "exclude": ["**/*.test.ts"],
    "include": ["LICENSE", "README.md", "src/", "migration.sql"]
  },
  "tasks": {
    "cd": "deno task ci && deno task publish:jsr",
    "ci:fix": "deno fmt && deno lint --fix",
    "ci:test": "deno check **/*.ts && deno test --allow-read",
    "ci": "deno task ci:fix && deno task ci:test",
    "dev": "deno test --watch --allow-read",
    "publish:jsr": "deno publish --allow-slow-types"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@openfeature/server-sdk": "npm:@openfeature/server-sdk@^1.13.0",
    "pg": "npm:pg@^8.13.0",
    "@electric-sql/pglite": "npm:@electric-sql/pglite@^0.3.0",
    "@middle-management/pglite-pg-adapter": "npm:@middle-management/pglite-pg-adapter@^0.0.4",
    "exponential-backoff": "npm:exponential-backoff@^3.1.2"
  }
}
