{
  "name": "@quad/openfeature-provider-postgres",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "exports": "./src/index.ts",
  "publish": {
    "exclude": ["**/*.test.ts", "src/pglite.ts"],
    "include": ["LICENSE", "README.md", "src/", "migration.sql"]
  },
  "tasks": {
    "cd": "deno task ci && deno task publish:jsr",
    "ci:fix": "deno fmt && deno lint --fix",
    "ci:test": "deno check --import-map import_map.test.json src/ && deno test --allow-read --import-map import_map.test.json",
    "ci": "deno task ci:fix && deno task ci:test",
    "dev": "deno test --watch --allow-read --import-map import_map.test.json",
    "publish:jsr": "deno publish"
  },
  "exclude": ["node_modules", "deno-ref"],
  "imports": {
    "@openfeature/server-sdk": "npm:@openfeature/server-sdk@^1.13.0",
    "pg": "npm:pg@^8.13.0",
    "exponential-backoff": "npm:exponential-backoff@^3.1.2"
  }
}
