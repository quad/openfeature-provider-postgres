{
  "name": "@quad/openfeature-provider-postgres",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "exports": "./src/provider.ts",
  "publish": {
    "exclude": ["**/*.test.ts"],
    "include": [
      "LICENSE",
      "README.md",
      "schema.sql",
      "src/"
    ]
  },
  "tasks": {
    "ci": "deno task ci:fix && deno test --allow-read --frozen",
    "ci:fix": "deno fmt && deno lint --fix",
    "dev": "deno test --watch --allow-read"
  },
  "imports": {
    "@electric-sql/pglite": "npm:@electric-sql/pglite@^0.3.0",

    "@middle-management/pglite-pg-adapter": "npm:@middle-management/pglite-pg-adapter@^0.0.4",
    "@openfeature/server-sdk": "npm:@openfeature/server-sdk@^1.13.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/async": "jsr:@std/async@^1",
    "@std/testing": "jsr:@std/testing@^1",
"pg": "npm:pg@^8.18.0",
    "xxh32": "npm:xxh32@^2.0.5"
  }
}
